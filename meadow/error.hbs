{{!< default}}

<div class="error-page">
    <div class="container">
        <div class="error-content">
            <p class="error-code">{{statusCode}}</p>
            <h1 class="error-title">
                {{#if (eq statusCode 404)}}
                    Page Not Found
                {{else}}
                    Something went wrong
                {{/if}}
            </h1>
            <p class="error-message">
                {{#if (eq statusCode 404)}}
                    The article or page you're looking for doesn't exist. It may have been moved or deleted.
                {{else}}
                    {{message}}
                {{/if}}
            </p>
            <a href="/" class="error-home-btn">Back to Home</a>
        </div>
    </div>
</div>

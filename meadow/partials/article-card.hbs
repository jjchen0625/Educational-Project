<article class="card">
    {{#if feature_image}}
    <a href="{{url}}" class="card-image-link" aria-hidden="true" tabindex="-1">
        <img class="card-image"
             src="{{img_url feature_image size="m"}}"
             alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}"
             loading="lazy" />
    </a>
    {{/if}}
    <div class="card-body">
        {{> category-badge}}
        <h3 class="card-title">
            <a href="{{url}}">{{title}}</a>
        </h3>
        {{#if excerpt}}
        <p class="card-excerpt">{{excerpt}}</p>
        {{/if}}
        <div class="card-meta">
            {{#primary_tag}}
            <span class="card-category" style="color: var(--color-{{slug}})">{{name}}</span>
            {{/primary_tag}}
            <span class="card-read-time">{{reading_time}}</span>
        </div>
    </div>
</article>

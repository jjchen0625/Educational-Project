<section class="newsletter-section">
    <div class="container">
        <div class="newsletter-inner">
            <div class="newsletter-left">
                <p class="newsletter-eyebrow">GET FIRST UPDATE</p>
                <h2 class="newsletter-headline">
                    Get smarter about money —
                    <span style="color: var(--color-stocks)">subscribe</span>
                    to our daily articles
                </h2>
            </div>
            <div class="newsletter-right">
                <form class="newsletter-form" data-members-form="subscribe">
                    <div class="newsletter-form-row">
                        <input
                            class="newsletter-input"
                            type="email"
                            name="email"
                            placeholder="Your email address"
                            required
                            data-members-email
                        />
                        <button class="newsletter-btn" type="submit">Subscribe</button>
                    </div>
                    <p class="newsletter-success" style="display:none">
                        You're in! Check your inbox to confirm.
                    </p>
                    <p class="newsletter-error" style="display:none">
                        Something went wrong. Please try again.
                    </p>
                </form>
            </div>
        </div>
    </div>
</section>

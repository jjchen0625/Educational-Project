<article class="card card--hero">
    {{#if feature_image}}
    <a href="{{url}}" class="card-hero-image-link" aria-hidden="true" tabindex="-1">
        <img class="card-hero-image"
             src="{{img_url feature_image size="l"}}"
             alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}" />
    </a>
    {{/if}}
    <div class="card-hero-content">
        {{> category-badge}}
        <h2 class="card-hero-title">
            <a href="{{url}}">{{title}}</a>
        </h2>
        {{#if excerpt}}
        <p class="card-hero-excerpt">{{excerpt}}</p>
        {{/if}}
        <div class="card-meta">
            {{#primary_tag}}
            <span class="card-category" style="color: var(--color-{{slug}})">{{name}}</span>
            {{/primary_tag}}
            <span class="card-read-time">{{reading_time}}</span>
        </div>
    </div>
</article>

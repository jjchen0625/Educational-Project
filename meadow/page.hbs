{{!< default}}

<div class="page-layout">
    <div class="container">
        <article class="page-content">
            <header class="page-header">
                <h1 class="page-title">{{title}}</h1>
            </header>

            {{#if feature_image}}
            <figure class="page-feature-image">
                <img src="{{feature_image}}" alt="{{title}}" />
            </figure>
            {{/if}}

            <div class="page-body gh-content">
                {{content}}
            </div>
        </article>
    </div>
</div>

{{> newsletter}}

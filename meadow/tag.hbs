{{!< default}}

<div class="tag-page">
    {{! Category header band }}
    <div class="tag-header">
        <div class="container">
            {{> category-badge}}
            <h1 class="tag-title">{{name}}</h1>
            {{#if description}}
            <p class="tag-description">{{description}}</p>
            {{/if}}
        </div>
    </div>

    <div class="container">
        {{! Featured post (first) }}
        {{#foreach posts limit="1"}}
        <div class="tag-hero">
            {{> article-card-hero}}
        </div>
        {{/foreach}}

        {{! Remaining posts in grid }}
        <div class="card-grid tag-grid">
            {{#foreach posts from="2"}}
                {{> article-card}}
            {{/foreach}}
        </div>

        {{pagination}}
    </div>
</div>

{{> footer}}
